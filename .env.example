# Supabase — get from supabase.com > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://YOURPROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Supabase direct DB connection (for server-side queries)
SUPABASE_DB_HOST=aws-0-eu-west-1.pooler.supabase.com
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres.YOURPROJECTREF
SUPABASE_DB_PASSWORD=your_password

# Alpha Vantage — free key at alphavantage.co
ALPHA_VANTAGE_KEY=YOUR_KEY_HERE

# Admin password for master view
ADMIN_PASSWORD=your_admin_password

# Next.js public URL (set in Vercel automatically)
NEXTAUTH_URL=https://your-app.vercel.app
