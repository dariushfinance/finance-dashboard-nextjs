# Supabase — get from supabase.com > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://YOURPROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Supabase direct DB connection (for server-side queries)
SUPABASE_DB_HOST=aws-0-eu-west-1.pooler.supabase.com
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres.YOURPROJECTREF
SUPABASE_DB_PASSWORD=your_password

# Alpha Vantage — free key at alphavantage.co
ALPHA_VANTAGE_KEY=YOUR_KEY_HERE

# Admin password for master view
ADMIN_PASSWORD=your_admin_password

# Next.js public URL (set in Vercel automatically)
NEXTAUTH_URL=https://your-app.vercel.app

# Stripe — get from dashboard.stripe.com
STRIPE_SECRET_KEY=sk_test_YOUR_KEY
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_KEY
STRIPE_WEBHOOK_SECRET=whsec_YOUR_SECRET
STRIPE_PRO_PRICE_ID=price_YOUR_PRO_PRICE_ID
STRIPE_PRO_MAX_PRICE_ID=price_YOUR_PRO_MAX_PRICE_ID
